# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# FastAPI/SQLAlchemy uses the psycopg v3 driver (psycopg[binary] in requirements.txt).
# Preferred: postgresql+psycopg://user:pass@host:port/db
# Render often provides postgres:// or postgresql:// — the app rewrites those to postgresql+psycopg:// at startup.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/procore_int

# ============================================
# Procore OAuth 2.0 Credentials
# ============================================
# Get these from: https://dev-portal-staging1.procoretech-qa.com (staging)
# Or: https://developer.procore.com (production)
# 
# Steps to get credentials:
# 1. Go to Procore Developer Portal
# 2. Create a new app
# 3. Set Redirect URI to: http://localhost:2000/api/procore/oauth/callback
# 4. Copy Client ID and Client Secret
PROCORE_CLIENT_ID=your_procore_client_id_here
PROCORE_CLIENT_SECRET=your_procore_client_secret_here

# OAuth Redirect URI (must match Procore app settings CHARACTER-FOR-CHARACTER)
#
# Local dev with `npm run dev`: the API runs on port 2000 (see root package.json + vite proxy).
# Use port 2000 here — NOT 3000. Wrong port → Procore often returns "unknown client" / auth failed.
# For local development:
PROCORE_REDIRECT_URI=http://localhost:2000/api/procore/oauth/callback
# For production: https://yourdomain.com/api/procore/oauth/callback
#
# Environment: production (default) uses login.procore.com + api.procore.com.
# Sandbox Developer Portal apps need sandbox — otherwise OAuth returns "unknown client" (401).
PROCORE_ENVIRONMENT=production
# PROCORE_ENVIRONMENT=sandbox

# ============================================
# AI API Keys (Optional - for AI features)
# ============================================
# Anthropic API Key for Claude AI
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key for GPT models
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Redis Configuration (Optional)
# ============================================
# Redis URL for caching and job queues
# Format: redis://username:password@host:port
# Leave empty if not using Redis
REDIS_URL=redis://localhost:6379

# ============================================
# Server Configuration
# ============================================
# Port for FastAPI server
PORT=2000
