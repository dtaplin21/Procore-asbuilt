# ============================================
# Database Configuration
# ============================================
# PostgreSQL connection string
# FastAPI/SQLAlchemy uses the psycopg v3 driver (psycopg[binary] in requirements.txt).
# Preferred: postgresql+psycopg://user:pass@host:port/db
# Render often provides postgres:// or postgresql:// — the app rewrites those to postgresql+psycopg:// at startup.
DATABASE_URL=postgresql+psycopg://user:password@localhost:5432/procore_int

# Render external URL example (append ?sslmode=require if needed):
# DATABASE_URL=postgresql://USER:PASSWORD@HOST.REGION-postgres.render.com:5432/DBNAME?sslmode=require

# development | production — use production on Render.
APP_ENV=development
# LOCAL DEV ONLY: if you see "SSL error: certificate verify failed" to cloud Postgres from macOS
# (common with bleeding-edge Python), set true while APP_ENV is development. Never on production.
# DATABASE_SSL_INSECURE_DEV=true

# ============================================
# Procore OAuth 2.0 Credentials
# ============================================
# Get these from: https://dev-portal-staging1.procoretech-qa.com (staging)
# Or: https://developer.procore.com (production)
# 
# Steps to get credentials:
# 1. Go to Procore Developer Portal
# 2. Create a new app
# 3. Set Redirect URI to: http://localhost:2000/api/procore/oauth/callback
# 4. Copy Client ID and Client Secret
PROCORE_CLIENT_ID=your_procore_client_id_here
PROCORE_CLIENT_SECRET=your_procore_client_secret_here

# OAuth Redirect URI (must match Procore app settings CHARACTER-FOR-CHARACTER)
#
# Local dev with `npm run dev`: the API runs on port 2000 (see root package.json + vite proxy).
# Use port 2000 here — NOT 3000. Wrong port → Procore often returns "unknown client" / auth failed.
# For local development:
PROCORE_REDIRECT_URI=http://localhost:2000/api/procore/oauth/callback
# For production: https://yourdomain.com/api/procore/oauth/callback
#
# Environment: production (default) uses login.procore.com + api.procore.com.
# Sandbox Developer Portal apps need sandbox — otherwise OAuth returns "unknown client" (401).
PROCORE_ENVIRONMENT=production
# PROCORE_ENVIRONMENT=sandbox

# ============================================
# Frontend (OAuth success redirect)
# ============================================
# After Procore OAuth, the API redirects the browser here (path /settings is appended).
# Production Vercel SPA for this project: https://procore-asbuilt.vercel.app
FRONTEND_PUBLIC_URL=http://localhost:5173
# Production API hosts: use the line below (or equivalent) instead of localhost.
# FRONTEND_PUBLIC_URL=https://procore-asbuilt.vercel.app

# ============================================
# CORS (production)
# ============================================
# Comma-separated browser origins allowed to call the API with credentials.
# Leave unset for local dev (localhost Vite + API ports only).
# FRONTEND_PUBLIC_URL is always added if not already in this list.
# Production: allow the Vercel SPA origin.
# CORS_ALLOW_ORIGINS=https://procore-asbuilt.vercel.app

# ============================================
# Production deploy — single host OR split (SPA + API)
# ============================================
# Procore OAuth redirect always targets the **API** host (where /api/procore/oauth/callback lives).
#
# Single origin (optional): one hostname serves Vite build + proxies /api (if you use that setup).
#
# Split (common): static SPA (e.g. Vercel) + API (e.g. Render). Then:
#
#   - SPA (this project): https://procore-asbuilt.vercel.app
#   - Procore Redirect URI: https://YOUR_API_HOST/api/procore/oauth/callback
#   - On the API host env: APP_ENV=production, PROCORE_REDIRECT_URI (same URL), DATABASE_URL, secrets, etc.
#     (never set DATABASE_SSL_INSECURE_DEV on Render)
#   - FRONTEND_PUBLIC_URL=https://procore-asbuilt.vercel.app (OAuth success redirect)
#   - CORS_ALLOW_ORIGINS=https://procore-asbuilt.vercel.app (FRONTEND_PUBLIC_URL is merged if missing)
#   - On the SPA build (Vercel): VITE_API_BASE_URL=https://YOUR_API_HOST  (no trailing slash)
#
# Preview deployments: Procore allows only registered redirect URIs; add each preview URL in
# Procore or use a staging app with sandbox credentials.

# ============================================
# AI API Keys (Optional - for AI features)
# ============================================
# Anthropic API Key for Claude AI
# Get from: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# OpenAI API Key for GPT models
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ============================================
# Redis Configuration (Optional)
# ============================================
# Redis URL for caching and job queues
# Format: redis://username:password@host:port
# Leave empty if not using Redis
REDIS_URL=redis://localhost:6379

# ============================================
# Server Configuration
# ============================================
# Port for FastAPI server
PORT=2000
