# Copy to `.env` for Drizzle (`npm run db:push`) and other root-level Node tools.
DATABASE_URL=postgresql://user:password@localhost:5432/procore_int

# Vite client (build-time). When the SPA and API use different hosts (e.g. Vercel + Render),
# set the public API origin with no trailing slash. Omit for local dev (Vite proxies /api).
# VITE_API_BASE_URL=https://your-api.example.com
